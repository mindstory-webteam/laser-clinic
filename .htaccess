RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Blog list clean URL
RewriteRule ^blogs/?$ blogs.php [L]

# Blog detail clean URL
RewriteRule ^blog/([a-zA-Z0-9-]+)/?$ blog-details.php?slug=$1 [L,QSA]

# Redirect old blog detail URL to clean URL
RewriteCond %{THE_REQUEST} \s/blog-details\.php\?slug=([a-zA-Z0-9-]+) [NC]
RewriteRule ^blog-details\.php$ /blog/%1? [R=301,L]

# Redirect blogs.php to /blogs
RewriteCond %{THE_REQUEST} \s/blogs\.php[\s?] [NC]
RewriteRule ^blogs\.php$ /blogs [R=301,L]

# Redirect index.html to homepage
RewriteCond %{THE_REQUEST} \s/index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Redirect .html URLs to clean URLs
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# Internally load .html files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)/?$ $1.html [L]